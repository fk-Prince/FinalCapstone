#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/proc/cygdrive/c/Users/princ/OneDrive/Desktop/FinalCapstone/node_modules/.pnpm/concurrently@10.0.0/node_modules/concurrently/dist/bin/node_modules:/proc/cygdrive/c/Users/princ/OneDrive/Desktop/FinalCapstone/node_modules/.pnpm/concurrently@10.0.0/node_modules/concurrently/dist/node_modules:/proc/cygdrive/c/Users/princ/OneDrive/Desktop/FinalCapstone/node_modules/.pnpm/concurrently@10.0.0/node_modules/concurrently/node_modules:/proc/cygdrive/c/Users/princ/OneDrive/Desktop/FinalCapstone/node_modules/.pnpm/concurrently@10.0.0/node_modules:/proc/cygdrive/c/Users/princ/OneDrive/Desktop/FinalCapstone/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/proc/cygdrive/c/Users/princ/OneDrive/Desktop/FinalCapstone/node_modules/.pnpm/concurrently@10.0.0/node_modules/concurrently/dist/bin/node_modules:/proc/cygdrive/c/Users/princ/OneDrive/Desktop/FinalCapstone/node_modules/.pnpm/concurrently@10.0.0/node_modules/concurrently/dist/node_modules:/proc/cygdrive/c/Users/princ/OneDrive/Desktop/FinalCapstone/node_modules/.pnpm/concurrently@10.0.0/node_modules/concurrently/node_modules:/proc/cygdrive/c/Users/princ/OneDrive/Desktop/FinalCapstone/node_modules/.pnpm/concurrently@10.0.0/node_modules:/proc/cygdrive/c/Users/princ/OneDrive/Desktop/FinalCapstone/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../concurrently/dist/bin/index.js" "$@"
else
  exec node  "$basedir/../concurrently/dist/bin/index.js" "$@"
fi
