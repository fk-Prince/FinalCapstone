{
    "name": "capstone",
    "version": "1.0.0",
    "description": "",
    "main": "index.js",
    "scripts": {
        "artisan": "cd server && php artisan serve",
        "client": "pnpm --prefix client run dev",
        "dev": "concurrently \"npm run artisan\" \"npm run client\"",
        "setup:server": "cd server && composer install && cp .env.example .env",
        "setup:client": "pnpm --prefix client install && cp client/.env.example client/.env",
        "setup": "npm run setup:server && npm run setup:client"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "packageManager": "pnpm@10.28.2",
    "devDependencies": {
        "concurrently": "^10.0.0"
    }
}
